################################################################################
# Root ignores for Peer-Evaluation-App-V1 (pnpm monorepo: backend, frontend,
# and Flask backend). Organized by stack. Keep examples tracked.
################################################################################

############################
# Node / pnpm / JavaScript #
############################
node_modules/
.pnpm-store/
.pnp.*
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Builds and caches
dist/
build/
lib/
.cache/
.tmp/
.temp/
.eslintcache
*.tsbuildinfo

# Vite/React (frontend)
frontend/dist/
frontend/.vite/

###########
# Testing #
###########
.coverage
coverage/
.nyc_output/
coverage.xml

########################
# Python / Flask stack #
########################
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
.eggs/
.python-version
env/
venv/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.cache/pip/
pip-wheel-metadata/
htmlcov/

# Flask instance runtime artifacts (don’t ignore the folder itself)
flask_backend/instance/*.db
flask_backend/instance/*.sqlite
flask_backend/instance/*.sqlite3
flask_backend/instance/*.pyc
flask_backend/instance/.env
flask_backend/instance/assignment_uploads/

########################
# Environment secrets  #
########################
# Generic env files at repo or package level
.env
.env.*
*.env
*.env.*

# Keep example envs tracked
!**/example.env
!.env.example

############
# Databases #
############
*.sqlite
*.sqlite3

########
# Logs #
########
*.log
logs/
log/

#########
# Docker #
#########
.docker/
docker-data/
docker-compose.override.yml

########
# IDEs  #
########
.vscode/
.idea/
*.swp
*.swo

#######
# OS  #
#######
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini